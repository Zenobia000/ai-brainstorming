  "breakpoints": [
    {
      "breakpoint": "640px",
      "prefix": "sm:",
      "direction": "min-width",
      "changes": [
        "nav-links: hidden → flex（sm:flex）",
        "hero: pb-16 → sm:pb-20, pt-24 → sm:pt-32",
        "hero-h1: text-4xl → sm:text-5xl",
        "hero-subtext: text-lg → sm:text-xl",
        "footer: flex-col → sm:flex-row",
        "pricing-grid: 1-col → sm:grid-cols-3",
        "demo-description: h2 text-[1.75rem] → sm:text-3xl"
      ]
    },
    {
      "breakpoint": "1024px",
      "prefix": "lg:",
      "direction": "min-width",
      "changes": [
        "hero-h1: sm:text-5xl → lg:text-6xl",
        "demo-layout: stack → lg:flex.items-start.gap-x-16",
        "demo-description: sticky top-24 (lg:sticky.lg:top-24)",
        "demo-description: w-auto → lg:w-96.lg:flex-none"
      ]
    }
  ],
  "effective_grid_system": {
